{
    "name": "@engineersamuel/istruthy",
    "version": "1.1.0",
    "description": "Truthiness with options",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "scripts": {
        "test": "vitest run --coverage",
        "test:watch": "vitest",
        "build": "rimraf dist .rollup-tmp && tsc -p tsconfig.build.json && rollup -c rollup.config.mjs && rimraf .rollup-tmp",
        "lint": "eslint .",
        "lint-fix": "eslint . --fix",
        "typecheck": "tsc --noEmit",
        "check": "npm run typecheck && npm run lint && npm test && npm run build",
        "release": "semantic-release"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/engineersamuel/isTruthy.git"
    },
    "keywords": [
        "truthy",
        "truthiness",
        "isTruthy",
        "isFalsy"
    ],
    "author": "Samuel Mendenhall <Samuel.Mendenhall@gmail.com>",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/engineersamuel/isTruthy/issues"
    },
    "homepage": "https://github.com/engineersamuel/isTruthy#readme",
    "devDependencies": {
        "@rollup/plugin-terser": "^1.0.0",
        "@semantic-release/git": "^10.0.1",
        "@vitest/coverage-v8": "^4.1.9",
        "eslint": "^10.6.0",
        "rimraf": "^6.1.3",
        "rollup": "^4.62.2",
        "semantic-release": "^25.0.5",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.62.1",
        "vitest": "^4.1.9"
    }
}
